<!-- app/views/customers/_customer.html.erb -->
<div class="customer-card">
  <div class="customer-image">
    <% if customer.image.attached? %>
      <%= image_tag customer.image, class: "customer-thumbnail" %>
    <% else %>
      <%= image_tag "default_profile.png", class: "customer-thumbnail" %>
    <% end %>
  </div>
  
  <div class="customer-details">
    <h3 class="customer-name"><%= customer.full_name %></h3>
    
    <div class="customer-contact">
      <% if customer.phone_number.present? %>
        <p><strong>Phone:</strong> <%= customer.phone_number %></p>
      <% end %>
      
      <% if customer.email_address.present? %>
        <p><strong>Email:</strong> <%= customer.email_address %></p>
      <% end %>
    </div>
    
    <% if customer.notes.present? %>
      <div class="customer-notes">
        <p><strong>Notes:</strong></p>
        <p><%= customer.notes %></p>
      </div>
    <% end %>
  </div>
</div>